# Backend environment variables (copy to `.env` and fill values).

# Server
PORT=2025

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=timesheet

# OTP Email (Gmail example used in `routes/user.js`)
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password_or_password

